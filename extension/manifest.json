{
  "manifest_version": 3,
  "name": "豆瓣我关注的阅读动态显示短评",
  "version": "1.1.0",
  "description": "改进了豆瓣本身只在我关注的阅读动态页面显示评分的缺陷，在友邻评分的旁边显示友邻短评。目前仅支持已读书籍。",
  "permissions": ["storage"],
  "host_permissions": [
    "https://book.douban.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://book.douban.com/updates*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}
